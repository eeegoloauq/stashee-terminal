<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>dev.stashee.Terminal</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Stashee</name>
  <summary>Glass tiling terminal that stashes your workflows</summary>
  <description>
    <p>
      Terminals are grouped into named workflows and tile automatically.
      Every pane runs inside tmux, so closing the app keeps every shell
      running; reopen, and they are back exactly where they were. SSH
      panes survive too.
    </p>
  </description>
  <launchable type="desktop-id">dev.stashee.Terminal.desktop</launchable>
  <developer id="dev.stashee">
    <name>Stashee contributors</name>
  </developer>
  <url type="homepage">https://github.com/eeegoloauq/stashee-terminal</url>
  <url type="bugtracker">https://github.com/eeegoloauq/stashee-terminal/issues</url>
  <url type="vcs-browser">https://github.com/eeegoloauq/stashee-terminal</url>
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/eeegoloauq/stashee-terminal/v0.1.3/docs/shots/agents.png</image>
      <caption>Two coding agents in a stashed workflow</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/eeegoloauq/stashee-terminal/v0.1.3/docs/shots/welcome.png</image>
      <caption>First launch</caption>
    </screenshot>
  </screenshots>
  <branding>
    <color type="primary" scheme_preference="light">#78aaff</color>
    <color type="primary" scheme_preference="dark">#10121a</color>
